# Firebase Admin (gerçek anahtarları asla repoya koymayın)
FIREBASE_SERVICE_ACCOUNT_JSON=

FIREBASE_DATABASE_URL=https://infuhub-c5ce7-default-rtdb.firebaseio.com

# Genel site kökü (e-posta linkleri, CORS ile aynı domain)
FRONTEND_URL=https://infuhub.ai
APP_URL=https://infuhub.ai
CLIENT_URL=https://infuhub.ai

# Takip linkleri https://infuhub.ai/c/:code — çoğu zaman FRONTEND_URL ile aynı
BASE_TRACKING_DOMAIN=https://infuhub.ai

# API kökü (aynı origin üzerinden /api proxy ise ekstra gerekmez)
# API_URL=https://infuhub.ai/api

# --- Google Workspace SMTP (Nodemailer, transactional tüm e-postalar) ---
# Uygulama şifresi: Google Hesabı → Güvenlik → 2 Adımlı Doğrulama → Uygulama şifreleri
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@infuhub.ai
SMTP_PASS=your_google_app_password
MAIL_FROM_NAME=INFUHUB
MAIL_FROM_EMAIL=no-reply@infuhub.ai
# (İsteğe bağlı) E-posta üst kısım logo — mutlak HTTPS URL; yoksa INFUHUB metin logosu
INFUHUB_LOGO_URL=https://infuhub.ai/brand/infuhub-logo.png
# (İsteğe bağlı) Geriye dönük: sadece MAIL_FROM_EMAIL yoksa kullanılır
# MAIL_FROM=no-reply@infuhub.ai

# İsteğe bağlı: SMTP oturum hata ayıklama (sunucu günlüklerinde ham SMTP trafiği)
# SMTP_DEBUG=true
# TLS sertifika doğrulamasını kapatma (sadece test; üretimde kullanmayın)
# SMTP_TLS_REJECT_UNAUTHORIZED=false

# Yalnızca geliştirme/teknik test: POST /api/admin/test-email (Bearer gerekir)
# ENABLE_TEST_EMAIL_ENDPOINT=true

# Kayıt e-posta kodu hash (üretimde güçlü rastgele değer)
# REGISTRATION_EMAIL_VERIFICATION_SECRET=

PORT=3002
