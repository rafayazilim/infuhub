# Vite — üretim derlemesinde .env.production kopyalanır veya bu değişkenler CI’da set edilir
VITE_API_BASE_URL=https://infuhub.ai
VITE_TRACKING_BASE_URL=https://infuhub.ai

# E-posta (Node backend): server/.env — Google Workspace örneği
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=no-reply@infuhub.ai
# SMTP_PASS=your_google_app_password
# MAIL_FROM_NAME=INFUHUB
# MAIL_FROM_EMAIL=no-reply@infuhub.ai
# INFUHUB_LOGO_URL=https://infuhub.ai/…/logo.png

# İsteğe bağlı takma adlar (projede doğrudan okunmuyorsa yine de dokümantasyon için)
# VITE_API_URL=https://infuhub.ai/api
# BASE_URL ve APP_URL: Vite’da import.meta.env.BASE_URL uygulama tabanıdır (genelde /)
# REACT_APP_*: Create React App kalıntısı; bu repo Vite kullanır
